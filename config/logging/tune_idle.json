{
  "name": "tune_idle",
  "description": "Standstill torque/velocity hunt detector for rigidity sweeps",
  "rate_hz": 100,
  "trigger": "manual",
  "log_subdir": "tune_idle",
  "context": ["enabled"],
  "channels": [
    {"id": "x_torque", "pin": "tune-torque.0.out", "label": "X TQ", "units": "%", "color": "#e74c3c", "group": "torque"},
    {"id": "y_torque", "pin": "tune-torque.1.out", "label": "Y TQ", "units": "%", "color": "#2ecc71", "group": "torque"},
    {"id": "z_torque", "pin": "tune-torque.2.out", "label": "Z TQ", "units": "%", "color": "#3498db", "group": "torque"},
    {"id": "a_torque", "pin": "tune-torque.3.out", "label": "A TQ", "units": "%", "color": "#f39c12", "group": "torque"},
    {"id": "x_vel", "pin": "tune-velocity.0.out", "label": "X Vel", "units": "mm/s", "color": "#1abc9c", "group": "velocity"},
    {"id": "y_vel", "pin": "tune-velocity.1.out", "label": "Y Vel", "units": "mm/s", "color": "#16a085", "group": "velocity"},
    {"id": "z_vel", "pin": "tune-velocity.2.out", "label": "Z Vel", "units": "mm/s", "color": "#2980b9", "group": "velocity"},
    {"id": "a_vel", "pin": "tune-velocity.3.out", "label": "A Vel", "units": "deg/s", "color": "#8e44ad", "group": "velocity"}
  ],
  "plot_groups": [
    {
      "id": "torque",
      "title": "Torque (% rated)",
      "y_mode": "sym",
      "channels": ["x_torque", "y_torque", "z_torque", "a_torque"]
    },
    {
      "id": "velocity",
      "title": "Velocity",
      "y_mode": "sym",
      "channels": ["x_vel", "y_vel", "z_vel", "a_vel"]
    }
  ]
}
