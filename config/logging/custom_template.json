{
  "name": "custom_template",
  "description": "Copy this file, edit pins/channels, and pass it to run_signal_logger.py --config",
  "rate_hz": 50,
  "trigger": "manual",
  "log_subdir": "custom",
  "context": ["line", "feed"],
  "channels": [
    {
      "id": "example_signal",
      "pin": "joint.0.f-error",
      "label": "Example",
      "units": "mm",
      "color": "#ffffff",
      "group": "main",
      "scale": 1.0
    }
  ],
  "plot_groups": [
    {
      "id": "main",
      "title": "Example plot",
      "y_mode": "auto",
      "y_min": null,
      "y_max": null,
      "channels": ["example_signal"]
    }
  ]
}
