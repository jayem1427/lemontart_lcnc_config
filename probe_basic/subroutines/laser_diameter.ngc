(author: jayem)
(date: 2026)
(Laser diameter — START is clear of beam; tip-find at START+beam_offset.)
(Reads HAL pin laser-beam-broken — does NOT use motion.probe-input / G38.)
(Prereqs: START X/Y + RPM #5501-#5503; Z-drop #5507; max travel #5508;)
(        beam offset #5509 = distance from START toward +X to beam/tip-find)
(START = operator capture beside the beam. Max travel = +X stop from START)
(        (safe inside slot, before far wall). Measure feeds +X only.)
(Sequence:)
(  1. G53 Z0 → tip-find XY (START_X+offset, START_Y) → slow tip-find)
(  2. Retract Z0 → START XY (clear side))
(  3. Drop to tip_z − Z_DROP → feed +X until break (pre-touch))
(  4. Retract X by 2 mm → M4 reverse spin-up (if RPM > 0))
(  5. Feed +X break→clear for diameter (stop at START+max_travel))
(Results: #5512 diameter, #5513/#5514 edges, #5515=1 on success, M68 E0/E1)

o<laser_diameter> sub
    o<400> if [#<_task> EQ 1]

    G21 G90
    M5

    #5515 = 0
    M68 E1 Q0

    #<start_x> = #5501
    #<start_y> = #5502
    #<probe_rpm> = #5503
    #<z_drop> = #5507
    #<max_travel> = #5508
    #<beam_offset> = #5509
    #<max_z_travel> = #5506
    #<fast_fr> = #3004
    #<slow_fr> = #3005
    #<step_z_coarse> = 0.20
    #<step_z_fine> = 0.02
    #<step_x> = 0.02
    #<min_remain> = 0.50
    #<x_backoff> = 2.0
    #<z_safe> = 0

    o<diam_drop> if [#<z_drop> LE 0]
      #<z_drop> = 2
    o<diam_drop> endif
    o<diam_trav> if [#<max_travel> LE 0]
      #<max_travel> = 20
    o<diam_trav> endif
    o<diam_off> if [#<beam_offset> LE 0]
      #<beam_offset> = 10
    o<diam_off> endif
    o<diam_ztrav> if [#<max_z_travel> LE 0]
      #<max_z_travel> = 30
    o<diam_ztrav> endif
    o<diam_feeds> if [#<fast_fr> LE 0]
      #<fast_fr> = 200
      #<slow_fr> = 40
    o<diam_feeds> endif

    o<diam_check_xy> if [[#<start_x> EQ 0] AND [#<start_y> EQ 0]]
      (DEBUG, LASER DIAM: set START X/Y first — clear of beam)
      o<laser_diameter> return
    o<diam_check_xy> endif

    o<diam_off_vs_trav> if [#<beam_offset> GE #<max_travel>]
      (DEBUG, LASER DIAM: BEAM OFFSET must be < MAX TRAVEL)
      o<laser_diameter> return
    o<diam_off_vs_trav> endif

    #<tip_x> = [#<start_x> + #<beam_offset>]
    #<x_stop> = [#<start_x> + #<max_travel>]
    #<z_limit> = [#<z_safe> - #<max_z_travel>]
    #<max_ok_diam> = [#<max_travel> - #<min_remain>]

    (DEBUG, LASER DIAM: tip-find at tip_x, measure START→x_stop)
    G53 G0 Z#<z_safe>
    G53 G0 X#<tip_x> Y#<start_y>

    (--- tip-find Z from Z0 at beam XY, spindle OFF ---)
    o<tip_c> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_coarse>]
      o<tip_cc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<tip_cc> endif
      G53 G1 Z#<z_next> F#<slow_fr>
    o<tip_c> endwhile

    o<diam_miss_tip_c> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: no beam trip on tip-find — check offset / polarity)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_miss_tip_c> endif

    #<z_backoff> = [#<_abs_z> + 1]
    o<tip_bo> if [#<z_backoff> GT #<z_safe>]
      #<z_backoff> = #<z_safe>
    o<tip_bo> endif
    G53 G0 Z#<z_backoff>

    o<tip_f> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_fine>]
      o<tip_fc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<tip_fc> endif
      G53 G1 Z#<z_next> F#<slow_fr>
    o<tip_f> endwhile

    o<diam_miss_tip_f> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: fine tip-find missed after coarse trip)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_miss_tip_f> endif

    #<tip_z> = #<_abs_z>
    #5510 = #<tip_z>
    #5519 = 1
    #<z_measure> = [#<tip_z> - #<z_drop>]

    (Retract Z0, move to START (clear of beam), drop to measure height)
    G53 G0 Z#<z_safe>
    G53 G0 X#<start_x> Y#<start_y>
    G53 G0 Z#<z_measure>

    o<diam_blocked> if [#<_hal[laser-beam-broken]> NE 0]
      (DEBUG, LASER DIAM: beam already broken at START — move START farther from beam)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_blocked> endif

    (--- pre-touch: feed +X until break, then back off 2 mm ---)
    o<pre> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_x> LT #<x_stop>]]
      #<x_next> = [#<_abs_x> + #<step_x>]
      o<prec> if [#<x_next> GT #<x_stop>]
        #<x_next> = #<x_stop>
      o<prec> endif
      G53 G1 X#<x_next> F#<slow_fr>
    o<pre> endwhile

    o<diam_miss_pre> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: pre-touch never broke before MAX TRAVEL)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_miss_pre> endif

    #<x_pre> = #<_abs_x>
    #<x_clear_start> = [#<x_pre> - #<x_backoff>]
    o<pre_xmin> if [#<x_clear_start> LT #<start_x>]
      #<x_clear_start> = #<start_x>
    o<pre_xmin> endif
    G53 G0 X#<x_clear_start>

    o<pre_still> if [#<_hal[laser-beam-broken]> NE 0]
      (DEBUG, LASER DIAM: still in beam after 2 mm X backoff)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<pre_still> endif

    o<diam_spin> if [#<probe_rpm> GT 0]
      M4 S#<probe_rpm>
      G4 P1.0
    o<diam_spin> endif

    (--- edge 1: feed +X until beam breaks ---)
    o<e1> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_x> LT #<x_stop>]]
      #<x_next> = [#<_abs_x> + #<step_x>]
      o<e1c> if [#<x_next> GT #<x_stop>]
        #<x_next> = #<x_stop>
      o<e1c> endif
      G53 G1 X#<x_next> F#<slow_fr>
    o<e1> endwhile

    o<diam_miss_e1> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: never broke beam before MAX TRAVEL)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_miss_e1> endif

    #<x_break> = #<_abs_x>
    #5513 = #<x_break>

    #<remain> = [#<x_stop> - #<x_break>]
    o<diam_risk> if [#<remain> LT #<min_remain>]
      (DEBUG, LASER DIAM: after break, remaining travel too small — raise MAX TRAVEL or smaller tool)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_risk> endif

    (--- edge 2: continue +X until beam clears ---)
    o<e2> while [[#<_hal[laser-beam-broken]> NE 0] AND [#<_abs_x> LT #<x_stop>]]
      #<x_next> = [#<_abs_x> + #<step_x>]
      o<e2c> if [#<x_next> GT #<x_stop>]
        #<x_next> = #<x_stop>
      o<e2c> endif
      G53 G1 X#<x_next> F#<slow_fr>
    o<e2> endwhile

    o<diam_miss_e2> if [#<_hal[laser-beam-broken]> NE 0]
      (DEBUG, LASER DIAM: never cleared before MAX TRAVEL — tool too big / stop too short)
      G53 G0 Z#<z_safe>
      M5
      o<laser_diameter> return
    o<diam_miss_e2> endif

    #<x_clear> = #<_abs_x>
    #5514 = #<x_clear>
    #<diameter> = [ABS[#<x_clear> - #<x_break>]]
    #5512 = #<diameter>

    o<diam_too_big> if [#<diameter> GT #<max_ok_diam>]
      (DEBUG, LASER DIAM: measured diameter exceeds travel window — reject)
      G53 G0 Z#<z_safe>
      M5
      M68 E0 Q#<diameter>
      M68 E1 Q0
      o<laser_diameter> return
    o<diam_too_big> endif

    #5515 = 1
    M68 E0 Q#<diameter>
    M68 E1 Q1

    G53 G0 Z#<z_safe>
    M5

    (DEBUG, LASER DIAM: break X=#5513 clear X=#5514 diameter=#5512)
    o<400> endif
o<laser_diameter> endsub

M2
