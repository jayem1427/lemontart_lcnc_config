(author: jayem)
(date: 2026)
(Laser diameter — tip-find Z, side clear, Z-drop, +X break→clear.)
(Reads HAL pin laser-beam-broken — does NOT use motion.probe-input / G38.)
(Prereqs: START X/Y + RPM #5501-#5503; Z-drop #5507; search #5508)
(Operator: jog to a safe Z above the beam before calling; START XY = slot center)
(Results: #5512 diameter, #5513/#5514 edges, #5515=1 on success, M68 E0/E1)

o<laser_diameter> sub
    o<400> if [#<_task> EQ 1]

    G21 G90

    (Clear prior success / analog publish)
    #5515 = 0
    M68 E1 Q0

    #<start_x> = #5501
    #<start_y> = #5502
    #<probe_rpm> = #5503
    #<z_drop> = #5507
    #<search> = #5508
    #<max_travel> = #5506
    #<fast_fr> = #3004
    #<slow_fr> = #3005
    #<step_z_coarse> = 0.20
    #<step_z_fine> = 0.02
    #<step_x> = 0.02
    #<min_remain> = 0.50

    o<diam_drop> if [#<z_drop> LE 0]
      #<z_drop> = 2
    o<diam_drop> endif
    o<diam_search> if [#<search> LE 0]
      #<search> = 10
    o<diam_search> endif
    o<diam_travel> if [#<max_travel> LE 0]
      #<max_travel> = 30
    o<diam_travel> endif
    o<diam_feeds> if [#<fast_fr> LE 0]
      #<fast_fr> = 200
      #<slow_fr> = 40
    o<diam_feeds> endif

    o<diam_check_xy> if [[#<start_x> EQ 0] AND [#<start_y> EQ 0]]
      (DEBUG, LASER DIAM: set START X/Y first)
      o<laser_diameter> return
    o<diam_check_xy> endif

    #<z_approach> = #<_abs_z>
    #<z_limit> = [#<z_approach> - #<max_travel>]
    #<x_left> = [#<start_x> - #<search>]
    #<x_right> = [#<start_x> + #<search>]
    #<max_ok_diam> = [[2 * #<search>] - #<min_remain>]

    (DEBUG, LASER DIAM: tip-find at START XY, then cross +X via laser-beam-broken)
    (Always clear Z before XY rapid)
    G53 G0 Z#<z_approach>
    G53 G0 X#<start_x> Y#<start_y>

    o<diam_spin> if [#<probe_rpm> GT 0]
      M3 S#<probe_rpm>
      G4 P1.0
    o<diam_spin> endif

    (--- tip-find Z: coarse then fine ---)
    o<tip_c> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_coarse>]
      o<tip_cc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<tip_cc> endif
      G53 G1 Z#<z_next> F#<fast_fr>
    o<tip_c> endwhile

    o<diam_miss_tip_c> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: no beam trip on tip-find — check XY / height / polarity)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_miss_tip_c> endif

    (Back off and fine-seek for a tighter tip Z)
    #<z_backoff> = [#<_abs_z> + 1]
    o<tip_bo> if [#<z_backoff> GT #<z_approach>]
      #<z_backoff> = #<z_approach>
    o<tip_bo> endif
    G53 G0 Z#<z_backoff>

    o<tip_f> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_fine>]
      o<tip_fc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<tip_fc> endif
      G53 G1 Z#<z_next> F#<slow_fr>
    o<tip_f> endwhile

    o<diam_miss_tip_f> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: fine tip-find missed after coarse trip)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_miss_tip_f> endif

    #<tip_z> = #<_abs_z>
    #5510 = #<tip_z>
    #5519 = 1
    #<z_measure> = [#<tip_z> - #<z_drop>]

    (Retract, go to clear start beside the beam, drop into measure height)
    G53 G0 Z#<z_approach>
    G53 G0 X#<x_left> Y#<start_y>
    G53 G0 Z#<z_measure>

    o<diam_blocked> if [#<_hal[laser-beam-broken]> NE 0]
      (DEBUG, LASER DIAM: beam already broken at X start — increase search or fix XY)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_blocked> endif

    (--- edge 1: feed +X until beam breaks ---)
    o<e1> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_x> LT #<x_right>]]
      #<x_next> = [#<_abs_x> + #<step_x>]
      o<e1c> if [#<x_next> GT #<x_right>]
        #<x_next> = #<x_right>
      o<e1c> endif
      G53 G1 X#<x_next> F#<slow_fr>
    o<e1> endwhile

    o<diam_miss_e1> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER DIAM: never broke beam on cross-feed)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_miss_e1> endif

    #<x_break> = #<_abs_x>
    #5513 = #<x_break>

    (Abort if not enough room left to clear without riding into the far fork)
    #<remain> = [#<x_right> - #<x_break>]
    o<diam_risk> if [#<remain> LT #<min_remain>]
      (DEBUG, LASER DIAM: after break, remaining travel too small — tool oversized / crash risk)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_risk> endif

    (--- edge 2: continue +X until beam clears ---)
    o<e2> while [[#<_hal[laser-beam-broken]> NE 0] AND [#<_abs_x> LT #<x_right>]]
      #<x_next> = [#<_abs_x> + #<step_x>]
      o<e2c> if [#<x_next> GT #<x_right>]
        #<x_next> = #<x_right>
      o<e2c> endif
      G53 G1 X#<x_next> F#<slow_fr>
    o<e2> endwhile

    o<diam_miss_e2> if [#<_hal[laser-beam-broken]> NE 0]
      (DEBUG, LASER DIAM: never cleared beam — tool larger than search?)
      G53 G0 Z#<z_approach>
      M5
      o<laser_diameter> return
    o<diam_miss_e2> endif

    #<x_clear> = #<_abs_x>
    #5514 = #<x_clear>
    #<diameter> = [ABS[#<x_clear> - #<x_break>]]
    #5512 = #<diameter>

    o<diam_too_big> if [#<diameter> GT #<max_ok_diam>]
      (DEBUG, LASER DIAM: measured diameter exceeds search window — reject)
      G53 G0 Z#<z_approach>
      M5
      M68 E0 Q#<diameter>
      M68 E1 Q0
      o<laser_diameter> return
    o<diam_too_big> endif

    #5515 = 1
    M68 E0 Q#<diameter>
    M68 E1 Q1

    G53 G0 Z#<z_approach>
    M5

    (DEBUG, LASER DIAM: break X=#5513 clear X=#5514 diameter=#5512 (Z-drop=#<z_drop>))
    o<400> endif
o<laser_diameter> endsub

M2
