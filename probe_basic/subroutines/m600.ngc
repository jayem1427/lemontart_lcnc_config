o<m600> sub
;Subprogram to start the "tool_touch_off 5.x.x" subroutine in automatic mode.
;Stand: 2024-12-10
;https://github.com/TooTall18T/tool_length_probe

; Capture T-word tool number before tool_touch_off clears #2000 (avoids stale _selected_tool)
#2002 = #<_selected_tool>
#2000 = 1
o<tool_touch_off> call
#2002 = 0


o<m600> endsub

M2 (end program)
