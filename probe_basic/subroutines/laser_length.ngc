(author: jayem)
(date: 2026)
(Laser tool length — G38 Z seek onto beam via motion.probe-input.)
(M62 P0 ONLY around G38 — never during G0/G1.)
(M63 P0 restores contact mux.)
(Prereqs: BEAM X/Y + RPM #5501-#5503; BEAM Z #5504)
(Tip-find at captured BEAM XY. START OFFSET #5509 is unused here.)
(Results: #5510 tip Z, #5511 length=beam_z-trip_z, #5515=1 on success, M68 E0/E1)

o<laser_length> sub
    o<400> if [#<_task> EQ 1]

    G21 G90
    M63 P0

    #5515 = 0
    M68 E1 Q0

    #<beam_x> = #5501
    #<beam_y> = #5502
    #<probe_rpm> = #5503
    #<beam_z> = #5504
    #<approach> = #5505
    #<max_travel> = #5506
    #<fast_fr> = #3004
    #<slow_fr> = #3005
    #<tip_coarse_fr> = 1200
    #<slow_z_fr> = 50

    o<len_defaults> if [#<approach> LE 0]
      #<approach> = 10
    o<len_defaults> endif
    o<len_travel> if [#<max_travel> LE 0]
      #<max_travel> = 30
    o<len_travel> endif
    o<len_feeds> if [#<fast_fr> LE 0]
      #<fast_fr> = #<tip_coarse_fr>
      #<slow_fr> = 40
    o<len_feeds> endif
    o<len_slow> if [#<slow_fr> LE 0]
      #<slow_fr> = 40
    o<len_slow> endif
    o<len_zslow> if [#<slow_z_fr> LE 0]
      #<slow_z_fr> = 50
    o<len_zslow> endif

    o<len_check_xy> if [[#<beam_x> EQ 0] AND [#<beam_y> EQ 0]]
      (DEBUG, LASER LENGTH: set BEAM X/Y first — tool blocking light)
      M63 P0
      o<laser_length> return
    o<len_check_xy> endif

    o<len_check_beam> if [#<beam_z> EQ 0]
      (DEBUG, LASER LENGTH: set BEAM Z #5504 first — teach via MDI)
      M63 P0
      o<laser_length> return
    o<len_check_beam> endif

    #<tip_x> = #<beam_x>
    #<tip_y> = #<beam_y>
    #<z_approach> = [#<beam_z> + #<approach>]
    #<z_limit> = [#<beam_z> - #<max_travel>]

    (seek at captured BEAM XY)
    G0 G53 Z#<z_approach>
    G0 G53 X#<tip_x> Y#<tip_y>

    o<len_spin> if [#<probe_rpm> GT 0]
      M3 S#<probe_rpm>
      G4 P1.0
    o<len_spin> endif

    (Coarse: one G1 to just above beam plane when clear, then G38 down)
    M66 P3 L0
    o<len_approach> if [#5399 EQ 0]
      #<z_coarse_target> = [#<beam_z> + 1.0]
      o<len_k_down> if [#<_abs_z> GT #<z_coarse_target>]
        G1 G53 Z#<z_coarse_target> F#<tip_coarse_fr>
      o<len_k_down> endif
    o<len_approach> endif

    M62 P0
    G91
    G38.3 Z[#<z_limit> - #<_abs_z>] F#<tip_coarse_fr>
    G90
    M63 P0
    o<len_miss_fast> if [#5070 EQ 0]
      (DEBUG, LASER LENGTH: no beam trip on coarse seek — check BEAM XY / BEAM Z / polarity)
      G0 G53 Z#<z_approach>
      M5
      M63 P0
      o<laser_length> return
    o<len_miss_fast> endif

    (Backoff with G0 G53 — absolute machine Z, mux OFF)
    #<z_backoff> = [#<_abs_z> + 1]
    o<len_bo> if [#<z_backoff> GT #<z_approach>]
      #<z_backoff> = #<z_approach>
    o<len_bo> endif
    G0 G53 Z#<z_backoff>

    M62 P0
    G91
    G38.3 Z[#<z_limit> - #<_abs_z>] F#<slow_z_fr>
    G90
    M63 P0
    o<len_miss_slow> if [#5070 EQ 0]
      (DEBUG, LASER LENGTH: no beam trip on fine seek)
      G0 G53 Z#<z_approach>
      M5
      M63 P0
      o<laser_length> return
    o<len_miss_slow> endif

    #<trip_z> = #<_abs_z>
    #5510 = #<trip_z>
    #5519 = 1

    #<tool_length> = [#<beam_z> - #<trip_z>]
    #5511 = #<tool_length>
    #5515 = 1

    M68 E0 Q#<tool_length>
    M68 E1 Q1

    G0 G53 Z#<z_approach>
    M5
    M63 P0

    (done: trip Z=#5510 length=#5511 = beam_z - tip_z)
    o<400> endif
o<laser_length> endsub

M2
