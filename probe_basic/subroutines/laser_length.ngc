(author: jayem)
(date: 2026)
(Laser tool length — Z seek onto beam via laser-beam-broken (no G38 / probe-input).)
(Prereqs: START X/Y + RPM #5501-#5503; BEAM Z #5504)
(Results: #5510 tip Z, #5511 length=beam_z-trip_z, #5515=1 on success, M68 E0/E1)

o<laser_length> sub
    o<400> if [#<_task> EQ 1]

    G21 G90

    #5515 = 0
    M68 E1 Q0

    #<start_x> = #5501
    #<start_y> = #5502
    #<probe_rpm> = #5503
    #<beam_z> = #5504
    #<approach> = #5505
    #<max_travel> = #5506
    #<fast_fr> = #3004
    #<slow_fr> = #3005
    #<step_z_coarse> = 0.20
    #<step_z_fine> = 0.02

    o<len_defaults> if [#<approach> LE 0]
      #<approach> = 10
    o<len_defaults> endif
    o<len_travel> if [#<max_travel> LE 0]
      #<max_travel> = 30
    o<len_travel> endif
    o<len_feeds> if [#<fast_fr> LE 0]
      #<fast_fr> = 200
      #<slow_fr> = 40
    o<len_feeds> endif

    o<len_check_xy> if [[#<start_x> EQ 0] AND [#<start_y> EQ 0]]
      (DEBUG, LASER LENGTH: set START X/Y first)
      o<laser_length> return
    o<len_check_xy> endif

    o<len_check_beam> if [#<beam_z> EQ 0]
      (DEBUG, LASER LENGTH: set BEAM Z (#5504) first — use CALIBRATE)
      o<laser_length> return
    o<len_check_beam> endif

    #<z_approach> = [#<beam_z> + #<approach>]
    #<z_limit> = [#<beam_z> - #<max_travel>]

    (DEBUG, LASER LENGTH: seek via laser-beam-broken)
    G53 G0 Z#<z_approach>
    G53 G0 X#<start_x> Y#<start_y>

    o<len_spin> if [#<probe_rpm> GT 0]
      M3 S#<probe_rpm>
      G4 P1.0
    o<len_spin> endif

    (Coarse seek toward beam)
    o<len_c> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_coarse>]
      o<len_cc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<len_cc> endif
      G53 G1 Z#<z_next> F#<fast_fr>
    o<len_c> endwhile

    o<len_miss_fast> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER LENGTH: no beam trip on coarse seek — check XY / BEAM Z / polarity)
      G53 G0 Z#<z_approach>
      M5
      o<laser_length> return
    o<len_miss_fast> endif

    (Absolute backoff — never G91 inch-ambiguous retract)
    #<z_backoff> = [#<_abs_z> + 1]
    o<len_bo> if [#<z_backoff> GT #<z_approach>]
      #<z_backoff> = #<z_approach>
    o<len_bo> endif
    G53 G0 Z#<z_backoff>

    (Fine seek)
    o<len_f> while [[#<_hal[laser-beam-broken]> EQ 0] AND [#<_abs_z> GT #<z_limit>]]
      #<z_next> = [#<_abs_z> - #<step_z_fine>]
      o<len_fc> if [#<z_next> LT #<z_limit>]
        #<z_next> = #<z_limit>
      o<len_fc> endif
      G53 G1 Z#<z_next> F#<slow_fr>
    o<len_f> endwhile

    o<len_miss_slow> if [#<_hal[laser-beam-broken]> EQ 0]
      (DEBUG, LASER LENGTH: no beam trip on fine seek)
      G53 G0 Z#<z_approach>
      M5
      o<laser_length> return
    o<len_miss_slow> endif

    #<trip_z> = #<_abs_z>
    #5510 = #<trip_z>
    #5519 = 1

    #<tool_length> = [#<beam_z> - #<trip_z>]
    #5511 = #<tool_length>
    #5515 = 1

    M68 E0 Q#<tool_length>
    M68 E1 Q1

    G53 G0 Z#<z_approach>
    M5

    (DEBUG, LASER LENGTH: trip Z=#5510  length=#5511 (beam_z - trip_z))
    o<400> endif
o<laser_length> endsub

M2
