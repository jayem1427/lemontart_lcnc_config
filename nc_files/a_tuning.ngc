G90          ; Absolute positioning
G0 A0        ; Start at zero

#1 = 10      ; Number of oscillation cycles
o100 while [#1 gt 0]
  G1 A90 F3600  ; Move to 90 deg
  G4 P0.5       ; Dwell 0.5s
  G1 A0 F3600   ; Return to 0
  G4 P0.5       ; Dwell 0.5s
  #1 = [#1 - 1]
o100 endwhile

M2           ; End program
