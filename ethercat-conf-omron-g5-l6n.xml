<masters>
  <!-- 1 ms servo period; -1 = no slave ref-clock sync (avoids random DC hitters) -->
  <master idx="0" appTimePeriod="1000000" refClockSyncCycles="-1">

    <!-- Omron G5 400 W — VID 0x83 / PID 0x007 — confirm with: ethercat slaves -->
    <slave idx="0" type="generic" vid="00000083" pid="00000007" name="G5-400W" configPdos="true">
      <!-- DC Sync0 for CSP -->
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="300000"/>
      <watchdog divider="2498" intervals="1000"/>

      <!-- Modes of operation = CSP (8) -->
      <sdoConfig idx="6060" subIdx="0"><sdoDataRaw data="08"/></sdoConfig>
      <!-- Follow-error window (counts) + timeout (ms) — retune 6065 for encoder -->
      <sdoConfig idx="6065" subIdx="00"><sdoDataRaw data="5C 0F 00 00"/></sdoConfig>
      <sdoConfig idx="6066" subIdx="00"><sdoDataRaw data="64 00"/></sdoConfig>

      <!-- Mailbox sync managers -->
      <syncManager idx="0" dir="out"/>
      <syncManager idx="1" dir="in"/>

      <!-- Master → drive (Omron RxPDO 0x1702) -->
      <syncManager idx="2" dir="out">
        <pdo idx="1702">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="ctrl-word"  halType="u32"/>
          <pdoEntry idx="607a" subIdx="00" bitLen="32" halPin="pos-cmd"    halType="s32"/>
        </pdo>
      </syncManager>

      <!-- Drive → master (Omron TxPDO 0x1b04) -->
      <syncManager idx="3" dir="in">
        <pdo idx="1b04">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="status-word" halType="u32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="pos-fb"     halType="s32"/>
          <!-- 60FD: function bits + di-1..di-5 on bits 4..8 — verify vs G5 manual -->
          <pdoEntry idx="60fd" subIdx="00" bitLen="32" halType="complex">
            <complexEntry bitLen="1" halPin="din-not"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-pot"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-dec"  halType="bit"/>
            <complexEntry bitLen="1"/>
            <complexEntry bitLen="1" halPin="di-1"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-2"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-3"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-4"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-5"     halType="bit"/>
            <complexEntry bitLen="7"/>
            <complexEntry bitLen="1" halPin="din-pc"   halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext1" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext2" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext3" halType="bit"/>
            <complexEntry bitLen="12"/>
          </pdoEntry>
        </pdo>
      </syncManager>
    </slave>

    <!-- Omron G5 200 W — VID 0x83 / PID 0x006 -->
    <slave idx="1" type="generic" vid="00000083" pid="00000006" name="G5-200W" configPdos="true">
      <!-- DC Sync0 for CSP -->
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="300000"/>
      <watchdog divider="2498" intervals="1000"/>
      <!-- Modes of operation = CSP (8) -->
      <sdoConfig idx="6060" subIdx="0"><sdoDataRaw data="08"/></sdoConfig>
      <!-- Follow-error window (counts) + timeout (ms) — retune 6065 for encoder -->
      <sdoConfig idx="6065" subIdx="00"><sdoDataRaw data="5C 0F 00 00"/></sdoConfig>
      <sdoConfig idx="6066" subIdx="00"><sdoDataRaw data="64 00"/></sdoConfig>
      <!-- Mailbox sync managers -->
      <syncManager idx="0" dir="out"/>
      <syncManager idx="1" dir="in"/>
      <!-- Master → drive -->
      <syncManager idx="2" dir="out">
        <pdo idx="1702">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="ctrl-word"  halType="u32"/>
          <pdoEntry idx="607a" subIdx="00" bitLen="32" halPin="pos-cmd"    halType="s32"/>
        </pdo>
      </syncManager>
      <!-- Drive → master -->
      <syncManager idx="3" dir="in">
        <pdo idx="1b04">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="status-word" halType="u32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="pos-fb"     halType="s32"/>
          <!-- 60FD: function bits + di-1..di-5 on bits 4..8 -->
          <pdoEntry idx="60fd" subIdx="00" bitLen="32" halType="complex">
            <complexEntry bitLen="1" halPin="din-not"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-pot"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-dec"  halType="bit"/>
            <complexEntry bitLen="1"/>
            <complexEntry bitLen="1" halPin="di-1"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-2"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-3"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-4"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-5"     halType="bit"/>
            <complexEntry bitLen="7"/>
            <complexEntry bitLen="1" halPin="din-pc"   halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext1" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext2" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext3" halType="bit"/>
            <complexEntry bitLen="12"/>
          </pdoEntry>
        </pdo>
      </syncManager>
    </slave>

    <!-- Omron G5 200 W — VID 0x83 / PID 0x006 -->
    <slave idx="2" type="generic" vid="00000083" pid="00000006" name="G5-200W" configPdos="true">
      <!-- DC Sync0 for CSP -->
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="300000"/>
      <watchdog divider="2498" intervals="1000"/>
      <!-- Modes of operation = CSP (8) -->
      <sdoConfig idx="6060" subIdx="0"><sdoDataRaw data="08"/></sdoConfig>
      <!-- Follow-error window (counts) + timeout (ms) — retune 6065 for encoder -->
      <sdoConfig idx="6065" subIdx="00"><sdoDataRaw data="5C 0F 00 00"/></sdoConfig>
      <sdoConfig idx="6066" subIdx="00"><sdoDataRaw data="64 00"/></sdoConfig>
      <!-- Mailbox sync managers -->
      <syncManager idx="0" dir="out"/>
      <syncManager idx="1" dir="in"/>
      <!-- Master → drive -->
      <syncManager idx="2" dir="out">
        <pdo idx="1702">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="ctrl-word"  halType="u32"/>
          <pdoEntry idx="607a" subIdx="00" bitLen="32" halPin="pos-cmd"    halType="s32"/>
        </pdo>
      </syncManager>
      <!-- Drive → master -->
      <syncManager idx="3" dir="in">
        <pdo idx="1b04">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="status-word" halType="u32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="pos-fb"     halType="s32"/>
          <!-- 60FD: function bits + di-1..di-5 on bits 4..8 -->
          <pdoEntry idx="60fd" subIdx="00" bitLen="32" halType="complex">
            <complexEntry bitLen="1" halPin="din-not"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-pot"  halType="bit"/>
            <complexEntry bitLen="1" halPin="din-dec"  halType="bit"/>
            <complexEntry bitLen="1"/>
            <complexEntry bitLen="1" halPin="di-1"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-2"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-3"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-4"     halType="bit"/>
            <complexEntry bitLen="1" halPin="di-5"     halType="bit"/>
            <complexEntry bitLen="7"/>
            <complexEntry bitLen="1" halPin="din-pc"   halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext1" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext2" halType="bit"/>
            <complexEntry bitLen="1" halPin="din-ext3" halType="bit"/>
            <complexEntry bitLen="12"/>
          </pdoEntry>
        </pdo>
      </syncManager>
    </slave>

    <!-- Leadshine L6N — VID 0x4321 / PID 0xE2 (from L6N ESI; series PID kept as L6N-400) -->
    <slave idx="3" type="generic" vid="00004321" pid="000000E2" name="L6N-100" configPdos="true">
      <!-- DC Sync0 for CSP -->
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="300000"/>
      <!-- Modes of operation = CSP (8) -->
      <sdoConfig idx="6060" subIdx="0"><sdoDataRaw data="08"/></sdoConfig>
      <!-- Follow-error window (counts) + timeout (ms) — retune 6065 for encoder -->
      <sdoConfig idx="6065" subIdx="00"><sdoDataRaw data="6D 00 00 00"/></sdoConfig>
      <sdoConfig idx="6066" subIdx="00"><sdoDataRaw data="64 00"/></sdoConfig>
      <!-- P04.00..05 = DI1..DI6 function (2400h..2405h). 0 = raw on 60FD bits 4..9 per L6N-S manual -->
      <sdoConfig idx="2400" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <sdoConfig idx="2401" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <sdoConfig idx="2402" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <sdoConfig idx="2403" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <sdoConfig idx="2404" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <sdoConfig idx="2405" subIdx="00"><sdoDataRaw data="00 00 00 00"/></sdoConfig>
      <!-- Master → drive (RxPDO 1600; slimmed from factory 6040/607A/60B8) -->
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="ctrl-word"  halType="u32"/>
          <pdoEntry idx="607a" subIdx="00" bitLen="32" halPin="pos-cmd"    halType="s32"/>
        </pdo>
      </syncManager>
      <!-- Drive → master (TxPDO 1A00) -->
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="status-word" halType="u32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="pos-fb"     halType="s32"/>
          <!-- 60FD per L6N-S: bit0 NOT,1 POT,2 HOME,4..9 DI1..DI6,26/27 Probe1/2 -->
          <pdoEntry idx="60fd" subIdx="00" bitLen="32" halType="complex">
            <complexEntry bitLen="1" halPin="neg-limit" halType="bit"/>
            <complexEntry bitLen="1" halPin="pos-limit" halType="bit"/>
            <complexEntry bitLen="1" halPin="home"      halType="bit"/>
            <complexEntry bitLen="1"/>
            <complexEntry bitLen="1" halPin="di-1"      halType="bit"/>
            <complexEntry bitLen="1" halPin="di-2"      halType="bit"/>
            <complexEntry bitLen="1" halPin="di-3"      halType="bit"/>
            <complexEntry bitLen="1" halPin="di-4"      halType="bit"/>
            <complexEntry bitLen="1" halPin="di-5"      halType="bit"/>
            <complexEntry bitLen="1" halPin="di-6"      halType="bit"/>
            <complexEntry bitLen="16"/>
            <complexEntry bitLen="1" halPin="probe1"    halType="bit"/>
            <complexEntry bitLen="1" halPin="probe2"    halType="bit"/>
            <complexEntry bitLen="4"/>
          </pdoEntry>
        </pdo>
      </syncManager>
